# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB connection string (Atlas SRV or direct)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production, set this to your actual domain(s).
# e.g. ALLOWED_ORIGINS=https://varakoto.com,https://www.varakoto.com
ALLOWED_ORIGINS=http://localhost:3000

# ─── Google Maps (optional — only needed to run distance scripts) ─────────────
# Used by: scripts/update-distances.ts, scripts/precompute-distances.ts,
#          scripts/calibrate-factor.ts, scripts/validate-with-google.ts
# Leave blank if you only want to run the API server.
GOOGLE_MAPS_API_KEY=
